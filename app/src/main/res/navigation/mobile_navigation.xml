<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.lucimanager.ui.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_interfaces"
            app:destination="@id/interfacesFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/interfacesFragment"
        android:name="com.example.lucimanager.ui.interfaces.InterfacesFragment"
        android:label="Network Interfaces"
        tools:layout="@layout/fragment_interfaces">
        <action
            android:id="@+id/action_interfaces_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/interfacesFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>